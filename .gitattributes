# Normalize line endings to LF in the repo; Git checks out with CRLF on Windows
* text=auto eol=lf

# Binary files — no line-ending conversion
*.exe   binary
*.ico   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ttf   binary
*.woff  binary
*.woff2 binary
*.zip   binary
